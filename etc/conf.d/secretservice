# /etc/conf.d/secretservice

# Server configuration
# SS_DOMAIN - Domain name (default: localhost)
# SS_PROXY - Enable proxy mode (default: no)
# SS_PATH - Path for data storage (default: /mnt/cache)
# SS_PORT - HTTP port (default: 80)
# SS_SSL - HTTPS port (default: 443)
# SS_CHUNK - Chunk size for file transfers (default: 1048576)

SS_DOMAIN="secretservice.au"
SS_PROXY="false"
SS_PATH="/mnt/cache"
SS_PORT="80"
SS_SSL="443"
SS_CHUNK="1048576"
